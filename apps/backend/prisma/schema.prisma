// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model User{
  id     String   @id   @default(uuid())
  username String
  email    String  @unique
  password String
  createdAt DateTime  @default(now())
  avatars  Avatar[]
  avatarvideos   AvatarVideo[]
}
model Avatar{
  id   String  @id  @default(cuid())
  userId   String
  name     String 
  createdAt DateTime  @default(now())
  avatarimages AvatarImage[]
  avatarvideo  AvatarVideo[]
  avatarvideorefrence   AvatarVideoReference[]
  user     User @relation(fields: [userId] , references: [id])
}
model AvatarImage{
  id   String    @id   @default(cuid())
  avatarid   String
  type       AvatarImageType
  url       String
  aspect_ratio  Aspectratio
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  avatar    Avatar @relation(fields: [avatarid] , references: [id])
}

model AvatarVideo {
  id      String   @id   @default(cuid())
  userId  String
  avatarId  String
  prompt    String
  startFrame  String?
  endFrame    String?
  aspect_ratio  Aspectratio
  status      AvatarVideoStatus
  VideoUrl   String?
  isPublic  Boolean   @default(false)
  remixFormId  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  avatar Avatar  @relation(fields: [avatarId], references: [id])
  avatarVideoRefrence AvatarVideoReference[]
  user     User @relation(fields: [userId] , references: [id])
  remixedFrom   AvatarVideo?      @relation("VideoRemix", fields: [remixFormId], references: [id])
  remixes       AvatarVideo[]     @relation("VideoRemix")
}

model AvatarVideoReference {
  id      String   @id   @default(cuid())
  avatarvideoId   String
  avatarId     String
  avatar    Avatar   @relation(fields: [avatarId], references: [id])
  avatarvideo  AvatarVideo  @relation(fields: [avatarvideoId], references: [id])
}

enum AvatarImageType {
  USER
  MODEL
}
enum AvatarVideoStatus {
  PENDING
  SUCCESS
  ERROR
}
enum Aspectratio {
  SQUARE
  PORTRAIT
  LANDSCAPE
  WIDE
}